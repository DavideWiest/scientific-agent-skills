font.family: serif
font.size: 8
axes.labelsize: 8
xtick.labelsize: 7
ytick.labelsize: 7
legend.fontsize: 7
figure.figsize: 3.25, 2.2
savefig.dpi: 300
savefig.bbox: tight
axes.spines.top: False
axes.spines.right: False
axes.prop_cycle: cycler('color', ['darkblue'])

# When a figure may be reused in a paper, slide, or website, also save a
# transparent-background artifact, e.g. fig.savefig(path, transparent=True).
